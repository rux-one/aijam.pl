<section class="py-12 sm:py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-2 sm:gap-3 mb-8 sm:mb-12">
      <span class="text-emerald-500 text-xl sm:text-2xl">//</span>
      <h1 class="text-3xl sm:text-4xl font-bold">archiwum_wydarzen</h1>
    </div>
    
    {{#if events}}
    <div class="mb-6 text-zinc-600 dark:text-zinc-400">
      <p class="text-sm sm:text-base">Łącznie: <span class="text-emerald-500 font-semibold">{{events.length}}</span> minionych wydarzeń</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      {{#each events}}
      {{#if url}}
      <a href="https://lu.ma/{{url}}" target="_blank" rel="noopener noreferrer" class="group p-4 sm:p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-600 transition-all duration-300 opacity-75 hover:opacity-100 block">
      {{else}}
      <div class="group p-4 sm:p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-600 transition-all duration-300 opacity-75 hover:opacity-100">
      {{/if}}
        <div class="flex items-start justify-between mb-3 sm:mb-4 gap-2">
          <span class="px-2 sm:px-3 py-1 text-xs font-medium bg-zinc-500/10 text-zinc-500 rounded-full whitespace-nowrap">{{type}}</span>
          <span class="text-xs sm:text-sm text-zinc-500 font-mono">{{date}}</span>
        </div>
        <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">{{title}}</h3>
        <p class="text-zinc-600 dark:text-zinc-400 text-sm mb-3 sm:mb-4 leading-relaxed">{{description}}</p>
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 text-xs sm:text-sm text-zinc-500">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="truncate">{{location}}</span>
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {{time}}
          </span>
          {{#if guest_count}}
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            {{guest_count}} uczestników
          </span>
          {{/if}}
        </div>
      {{#if url}}
      </a>
      {{else}}
      </div>
      {{/if}}
      {{/each}}
    </div>
    {{else}}
    <div class="text-center py-12 sm:py-20">
      <div class="text-6xl sm:text-8xl mb-4 opacity-20">📚</div>
      <p class="text-lg sm:text-xl text-zinc-600 dark:text-zinc-400">Brak minionych wydarzeń w archiwum</p>
    </div>
    {{/if}}
    
    <div class="mt-12 text-center">
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-300 dark:border-zinc-700 rounded-lg hover:border-emerald-500 active:border-emerald-600 transition-colors text-sm sm:text-base">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Powrót do strony głównej
      </a>
    </div>
  </div>
</section>
