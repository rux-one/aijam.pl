<section class="min-h-[60vh] sm:min-h-[70vh] flex items-center justify-center px-4 sm:px-6 py-12 sm:py-20">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-block mb-4 sm:mb-6 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full border border-emerald-500/30 bg-emerald-500/5">
      <span class="text-emerald-500 text-xs sm:text-sm">● status: {{hero.status}}</span>
    </div>
    <h1 id="hero-title" class="text-4xl sm:text-5xl md:text-7xl font-bold mb-4 sm:mb-6 tracking-tight leading-tight">
      <span class="text-emerald-500">&gt;</span> {{hero.title}}
    </h1>
    <p id="hero-tagline" class="text-lg sm:text-xl md:text-2xl text-zinc-600 dark:text-zinc-400 mb-6 sm:mb-8 px-2 leading-relaxed">
      {{hero.tagline}}
    </p>
    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center px-4">
      <a href="/join/" class="px-6 sm:px-8 py-3 sm:py-4 bg-emerald-500 text-zinc-950 font-semibold rounded-lg hover:bg-emerald-400 active:bg-emerald-600 transition-colors touch-manipulation text-sm sm:text-base">
        $ dolacz --teraz
      </a>
      <a href="/events/" class="px-6 sm:px-8 py-3 sm:py-4 border border-zinc-300 dark:border-zinc-700 rounded-lg hover:border-emerald-500 active:border-emerald-600 transition-colors touch-manipulation text-sm sm:text-base">
        $ zobacz --wydarzenia
      </a>
    </div>
  </div>
</section>

<section class="border-y border-zinc-200 dark:border-zinc-800 bg-white/50 dark:bg-zinc-900/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-8 grid grid-cols-2 md:grid-cols-3 gap-4 sm:gap-8 text-center">
    {{#each stats}}
    <div>
      <div class="text-3xl sm:text-4xl font-bold text-emerald-500">{{value}}</div>
      <div class="text-xs sm:text-sm text-zinc-500">{{label}}</div>
    </div>
    {{/each}}
  </div>
</section>

<section id="events" class="py-12 sm:py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8 sm:mb-12">
      <div class="flex items-center gap-2 sm:gap-3">
        <span class="text-emerald-500 text-xl sm:text-2xl">//</span>
        <h2 class="text-2xl sm:text-3xl font-bold">nadchodzace_wydarzenia</h2>
      </div>
      <a href="/archiwum/" class="text-xs sm:text-sm text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors flex items-center gap-1">
        <span>archiwum</span>
        <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {{#each events}}
      {{#if url}}
      <a href="https://lu.ma/{{url}}" target="_blank" rel="noopener noreferrer" class="group p-4 sm:p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-zinc-900 hover:border-emerald-500 active:border-emerald-600 transition-all duration-300 touch-manipulation block">
      {{else}}
      <div class="group p-4 sm:p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-zinc-900 hover:border-emerald-500 active:border-emerald-600 transition-all duration-300 touch-manipulation">
      {{/if}}
        <div class="flex items-start justify-between mb-3 sm:mb-4 gap-2">
          <span class="px-2 sm:px-3 py-1 text-xs font-medium bg-{{#if (eq type 'warsztat')}}emerald{{else}}cyan{{/if}}-500/10 text-{{#if (eq type 'warsztat')}}emerald{{else}}cyan{{/if}}-500 rounded-full whitespace-nowrap">{{type}}</span>
          <span class="text-xs sm:text-sm text-zinc-500 font-mono">{{date}}</span>
        </div>
        <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 group-hover:text-emerald-500 transition-colors">{{title}}</h3>
        <p class="text-zinc-600 dark:text-zinc-400 text-sm mb-3 sm:mb-4 leading-relaxed">{{description}}</p>
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 text-xs sm:text-sm text-zinc-500">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="truncate">{{location}}</span>
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {{time}}
          </span>
        </div>
      {{#if spots_remaining}}
      <span class="flex items-center gap-1 text-emerald-500">
        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {{spots_remaining}} miejsc
      </span>
      {{/if}}
      {{#if url}}
      </a>
      {{else}}
      </div>
      {{/if}}
      {{/each}}
    </div>
    {{!-- <div class="mt-6 sm:mt-8 text-center">
      <button class="px-5 sm:px-6 py-2.5 sm:py-3 text-xs sm:text-sm border border-zinc-300 dark:border-zinc-700 rounded-lg hover:border-emerald-500 active:border-emerald-600 transition-colors touch-manipulation">
        $ zaladuj --wiecej-wydarzen
      </button>
    </div> --}}
  </div>
</section>

<section id="about" class="py-12 sm:py-20 px-4 sm:px-6 bg-zinc-100/50 dark:bg-zinc-900/50">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-2 sm:gap-3 mb-8 sm:mb-12">
      <span class="text-emerald-500 text-xl sm:text-2xl">//</span>
      <h2 class="text-2xl sm:text-3xl font-bold">o_nas</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
      <div>
        <p class="text-base sm:text-lg text-zinc-600 dark:text-zinc-400 mb-5 sm:mb-6 leading-relaxed">
          {{about.description}}
        </p>
        <div class="space-y-3 sm:space-y-4">
          {{#each about.features}}
          <div class="flex items-center gap-2 sm:gap-3">
            <span class="text-emerald-500 flex-shrink-0">✓</span>
            <span class="text-sm sm:text-base">{{this}}</span>
          </div>
          {{/each}}
        </div>
      </div>
      <div class="p-4 sm:p-6 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white dark:bg-zinc-900 font-mono text-xs sm:text-sm">
        <div class="flex items-center gap-1.5 sm:gap-2 mb-3 sm:mb-4 text-zinc-500">
          <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-red-500"></span>
          <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-yellow-500"></span>
          <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-500"></span>
          <span class="ml-1 sm:ml-2 text-xs sm:text-sm">terminal</span>
        </div>
        <pre class="text-zinc-600 dark:text-zinc-400 overflow-x-auto"><code><span class="text-emerald-500">$</span> cat tematy.txt

{{#each about.topics}}
<span class="text-cyan-500">{{#if @last}}└──{{else}}├──{{/if}}</span> {{this}}
{{/each}}

<span class="text-emerald-500">$</span> <span class="cursor-blink"></span></code></pre>
      </div>
    </div>
  </div>
</section>

<section id="join" class="py-12 sm:py-20 px-4 sm:px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="flex items-center justify-center gap-2 sm:gap-3 mb-6 sm:mb-8">
      <span class="text-emerald-500 text-xl sm:text-2xl">//</span>
      <h2 class="text-2xl sm:text-3xl font-bold">dolacz_do_nas</h2>
    </div>
    <p class="text-zinc-600 dark:text-zinc-400 mb-6 sm:mb-8 text-sm sm:text-base px-4">
      Zostaw swój email, a będziemy informować Cię o nadchodzących wydarzeniach i dyskusjach.
    </p>
    <form id="join-form" class="flex flex-col sm:flex-row gap-3 sm:gap-4 max-w-md mx-auto px-4">
      <input type="email" id="email-input" placeholder="twoj@email.pl" class="flex-1 px-4 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 focus:border-emerald-500 focus:outline-none transition-colors font-mono text-sm sm:text-base touch-manipulation" required>
      <button type="submit" class="px-6 py-3 bg-emerald-500 text-zinc-950 font-semibold rounded-lg hover:bg-emerald-400 active:bg-emerald-600 transition-colors whitespace-nowrap touch-manipulation text-sm sm:text-base">
        $ subskrybuj
      </button>
    </form>
    <p id="form-message" class="mt-3 sm:mt-4 text-xs sm:text-sm text-emerald-500 hidden px-4"></p>
    <div class="mt-8 sm:mt-12 flex justify-center gap-4 sm:gap-6">
      <a href="{{social.linkedin}}" class="p-2.5 sm:p-3 border border-zinc-300 dark:border-zinc-700 rounded-lg hover:border-emerald-500 active:border-emerald-600 transition-colors touch-manipulation" aria-label="LinkedIn">
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
      </a>
      <a href="{{social.github}}" class="p-2.5 sm:p-3 border border-zinc-300 dark:border-zinc-700 rounded-lg hover:border-emerald-500 active:border-emerald-600 transition-colors touch-manipulation" aria-label="GitHub">
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
      </a>
    </div>
  </div>
</section>
