# Events API Endpoints
# These endpoints should return a JSON response with Luma events schema
# See docs/luma_events.json for the expected format
EVENTS_ENDPOINT_PAST=http://localhost:1337/luma_events.json
EVENTS_ENDPOINT_UPCOMING=http://localhost:1337/luma_events.json

# Optional: API timeout in milliseconds
EVENTS_TIMEOUT=5000
